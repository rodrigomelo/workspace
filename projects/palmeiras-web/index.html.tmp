        .match-item { perspective: 1000px; }
        .match-item .match-front, .match-item .match-back {
            backface-visibility: hidden;
            transition: transform 0.6s;
            transform-style: preserve-3d;
        }
        .match-item .match-back {
            display: none;
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: var(--palmeiras-green);
            border-radius: 12px;
            color: white;
        }
        .match-item.flipped .match-front { display: none; }
        .match-item.flipped .match-back { display: block; }
